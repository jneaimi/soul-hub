{
	"name": "soul-hub",
	"version": "2.0.0",
	"description": "AI-human collaboration command center — project management, pipeline orchestration, and a knowledge vault, powered by Claude Code",
	"license": "MIT",
	"author": "Jasem Al Neaimi",
	"repository": {
		"type": "git",
		"url": "https://github.com/jneaimi/soul-hub.git"
	},
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"postinstall": "npm rebuild node-pty || true",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"prod:start": "npx pm2 start ecosystem.config.cjs",
		"prod:stop": "npx pm2 stop ecosystem.config.cjs",
		"prod:restart": "npx pm2 restart soul-hub",
		"prod:reload": "npx pm2 reload soul-hub",
		"prod:status": "npx pm2 status",
		"prod:logs": "npx pm2 logs",
		"prod:startup": "npx pm2 startup && npx pm2 save"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.56.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.5.2",
		"@types/node-cron": "^3.0.11",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.3"
	},
	"dependencies": {
		"@xterm/addon-canvas": "^0.7.0",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/addon-unicode11": "^0.9.0",
		"@xterm/addon-web-links": "^0.12.0",
		"@xterm/addon-webgl": "^0.19.0",
		"@xterm/xterm": "^6.0.0",
		"chokidar": "^5.0.0",
		"graphology": "^0.26.0",
		"graphology-layout-forceatlas2": "^0.10.1",
		"graphology-types": "^0.24.8",
		"gray-matter": "^4.0.3",
		"marked": "^17.0.6",
		"minisearch": "^7.2.0",
		"node-cron": "^4.2.1",
		"node-pty": "^1.1.0",
		"pm2": "^6.0.14",
		"shiki": "^4.0.2",
		"sigma": "^3.0.2",
		"yaml": "^2.8.3"
	}
}
